<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Encabezado rojo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:background="#B71C1C"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="22dp"
                android:paddingEnd="20dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnMenu"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="☰"
                        android:textColor="#B71C1C"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btnNotificaciones"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="8dp"
                        android:background="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="🔔"
                        android:textColor="#B71C1C"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/btnPerfil"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="👤"
                        android:textColor="#B71C1C"
                        android:textSize="18sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSaludo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="¡Hola, Alumno!"
                    android:textColor="#FFFFFF"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="usuario@ues.edu.sv"
                    android:textColor="#FFCDD2"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Contenido -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Tarjeta resumen académico -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-38dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resumen académico"
                            android:textColor="#B71C1C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNombreGrupo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Grupo de Investigación 01"
                            android:textColor="#212121"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTemaGrupo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Sistema de seguimiento académico"
                            android:textColor="#666666"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnVerGrupo"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="18dp"
                            android:backgroundTint="#B71C1C"
                            android:text="Ver grupo"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tarjeta estado -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado del trabajo"
                            android:textColor="#212121"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNombreProyectoEstado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Sistema de seguimiento académico"
                            android:textColor="#555555"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvEstadoResumen"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Estado: 1 aprobada, 2 denegadas"
                            android:textColor="#B71C1C"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnVerDetallePropuestas"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFEBEE"
                            android:text="Ver detalle de propuestas"
                            android:textAllCaps="false"
                            android:textColor="#B71C1C" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tarjeta notas -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notas registradas"
                            android:textColor="#212121"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEtapa1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="#F5F5F5"
                            android:padding="12dp"
                            android:text="Etapa 1: ---"
                            android:textColor="#212121"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvEtapa2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#F5F5F5"
                            android:padding="12dp"
                            android:text="Etapa 2: ---"
                            android:textColor="#212121"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvEtapa3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#F5F5F5"
                            android:padding="12dp"
                            android:text="Etapa 3: ---"
                            android:textColor="#212121"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvEtapa4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#F5F5F5"
                            android:padding="12dp"
                            android:text="Etapa 4: ---"
                            android:textColor="#212121"
                            android:textSize="15sp" />

                        <Button
                            android:id="@+id/btnAbrirNotas"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#B71C1C"
                            android:text="Abrir detalle de notas"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btnRegistrarPropuestas"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="#D32F2F"
                    android:text="Registrar nueva propuesta"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="14dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Barra inferior blanca con acento rojo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Inicio"
            android:textColor="#B71C1C"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNavGrupos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Grupo"
            android:textColor="#666666"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Salir"
            android:textColor="#B71C1C"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>