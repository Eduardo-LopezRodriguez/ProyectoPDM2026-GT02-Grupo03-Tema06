<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4"
    tools:context=".ui.Alumno.DetalleGruposTGIAlumnosActivity">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerEstudiante"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#B40000"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- BOTON REGRESAR/BACK -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Volver"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvTituloHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi grupo"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- BOTON NOTIFICACIONES-->
                <ImageButton
                    android:id="@+id/btnNotificaciones"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Notificaciones"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#FFFFFF" />

                <!-- BOTON PERFIL -->
                <ImageButton
                    android:id="@+id/btnPerfil"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Perfil"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#FFFFFF" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/ivEscudoGrupo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_escudo_ues"
                android:contentDescription="Escudo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNombreGrupo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grupo de Investigación 01"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTemaGrupo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Sistema de seguimiento académico"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_bottom_nav_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="58dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_nav_selected_red"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavGrupos"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavPerfil"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!--CONTENIDO/CUERPO -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerEstudiante"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!--CARD INFORMACION GRUPO -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGrupoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#D8D8D8"
                app:strokeWidth="1dp">

                <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDirectorTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Director: Ing. César Augusto"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1.5dp"
                    android:background="#D8D8D8"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        app:tint="#000000"
                        android:contentDescription="Avatar" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allan Anduray"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AA20001"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!--BOTON INFORMACION USUARIO 1-->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUsuarioInfo1"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Información"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#D3D3D3"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E5E5"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        app:tint="#000000"
                        android:contentDescription="Avatar" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oscar Cordoba"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AC21036"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!--BOTON INFORMACION USUARIO 2-->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUsuarioInfo2"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Información"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#D3D3D3"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E5E5"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        app:tint="#000000"
                        android:contentDescription="Avatar" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eduardo López"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LR21008"
                            android:textColor="#777777"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!--BOTON INFORMACION USUARIO 3-->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUsuarioInfo3"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Información"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#D3D3D3"
                        app:cornerRadius="6dp" />
                </LinearLayout>

            </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--CARD JURADOS ASIGNADOS-->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPropuesta1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#D8D8D8"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Jurados asignados"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/ivFlecha"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivFlecha"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:layout_constraintBottom_toBottomOf="@+id/tvTitulo"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tvTitulo"
                        app:srcCompat="@drawable/outline_arrow_forward_ios_24"
                        app:tint="#000000" />

                    <View
                        android:id="@+id/lineaDivisoria"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="#CCCCCC"
                        app:layout_constraintTop_toBottomOf="@+id/tvTitulo" />

                    <!--TEXTVIEW PROPUESTAS-->
                    <TextView
                        android:id="@+id/tvPropuestas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="3 propuestas registradas. 1 seleccionada"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        app:layout_constraintTop_toBottomOf="@+id/lineaDivisoria" />

                    <View
                        android:id="@+id/lineaDivisoria2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@+id/tvPropuestas" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        app:layout_constraintTop_toBottomOf="@+id/lineaDivisoria2">

                        <!--BOTON VER PROPUESTAS-->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnVerPropuestas"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Ver propuestas"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            app:backgroundTint="#D3D3D3"
                            app:cornerRadius="8dp" />

                        <!--BOTON SUBIR TESIS-->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSubirTesis"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Subir tesis"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            app:backgroundTint="#A00000"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--CARD TESIS GRUPO-->
            <com.google.android.material.card.MaterialCardView
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardTesisGrupo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#D8D8D8"
                app:strokeWidth="1dp">

                <!--WIGET PARA CARD TESIS GRUPO-->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloTesis"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Tesis del grupo"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivFlechaTesis" />

                    <ImageView
                        android:id="@+id/ivFlechaTesis"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/outline_arrow_forward_ios_24"
                        app:tint="#000000"
                        app:layout_constraintTop_toTopOf="@id/tvTituloTesis"
                        app:layout_constraintBottom_toBottomOf="@id/tvTituloTesis"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/lineaDivisoriaTesis1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="#CCCCCC"
                        app:layout_constraintTop_toBottomOf="@id/tvTituloTesis" />

                    <TextView
                        android:id="@+id/tvNombreTesis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Implementación del sistema de seguimiento académico para la UES"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        app:layout_constraintTop_toBottomOf="@id/lineaDivisoriaTesis1" />

                    <View
                        android:id="@+id/lineaDivisoriaTesis2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@id/tvNombreTesis" />

                    <!--CONTENEDOR PARA ESTADOS TESIS-->
                    <LinearLayout
                        android:id="@+id/contenedorEstados"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/lineaDivisoriaTesis2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnHistorialTesis">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Estado: "
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <!--ESTADO TESIS-->
                            <TextView
                                android:id="@+id/tvEstadoValor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No subida"
                                android:textColor="#D97706"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ultima versión: "
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <!--VERSION TESIS-->
                            <TextView
                                android:id="@+id/tvVersionValor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No enviada"
                                android:textColor="#555555"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!--BOTON HISTORIAL TESIS-->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHistorialTesis"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historial"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        app:backgroundTint="#D3D3D3"
                        app:cornerRadius="8dp"
                        app:layout_constraintBottom_toBottomOf="@id/contenedorEstados"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/contenedorEstados" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--CARD NOTAS-->
            <com.google.android.material.card.MaterialCardView
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardMisNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#D8D8D8"
                app:strokeWidth="1dp">

                <!--WIDGET CARD NOTAS-->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTituloNotas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Mis notas"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivFlechaNotas" />

                    <ImageView
                        android:id="@+id/ivFlechaNotas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:srcCompat="@drawable/outline_arrow_forward_ios_24"
                        app:tint="#000000"
                        app:layout_constraintTop_toTopOf="@id/tvTituloNotas"
                        app:layout_constraintBottom_toBottomOf="@id/tvTituloNotas"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/lineaDivisoriaNotas1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="#CCCCCC"
                        app:layout_constraintTop_toBottomOf="@id/tvTituloNotas" />

                    <LinearLayout
                        android:id="@+id/contenedorEtapas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/lineaDivisoriaNotas1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <!--NOTA ETAPA 1-->
                            <TextView
                                android:id="@+id/tvNotaEtapa1"
